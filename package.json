{
  "name": "nairobi-devops",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "security:generate": "node scripts/generate-security-headers.js",
    "dev": "npm run security:generate && vite",
    "check:lint": "npm run lint",
    "check:types": "npm run typecheck",
    "check:format": "npm run format:check",
    "update:node-engine": "node scripts/check-node-engine.js",
    "check": "npm run check:lint && npm run check:types && npm run check:format",
    "build": "npm run security:generate && npm run check && vite build --mode production && node scripts/setup-cpanel.js",
    "build:staging": "npm run security:generate && vite build --mode staging && node scripts/setup-cpanel.js",
    "build:prod": "npm run build",
    "build:ci": "npm run build",
    "build:ci:staging": "npm run build:staging",
    "preview": "vite preview",
    "test": "vitest run --root client",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:coverage": "vitest run --root client --coverage",
    "test:ui": "vitest --root client --ui",
    "sitemap:generate": "tsx scripts/generate-sitemap.ts",
    "sitemap:validate": "tsx scripts/validate-sitemap.ts",
    "sitemap:deploy": "bash scripts/deploy-sitemap.sh",
    "sitemap:test": "tsx scripts/test-strict-validation.ts"
  },
