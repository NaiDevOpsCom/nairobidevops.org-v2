# Cloudinary Configuration
# Get your cloud name from the Cloudinary Dashboard
VITE_CLOUDINARY_CLOUD_NAME=

# PHP Proxy Credentials (Local Dev)
# These are only needed if you are running the PHP proxy locally.
# On cPanel, these should be set as environment variables.
# Note: VITE_CLOUDINARY_CLOUD_NAME and CLD_CLOUD_NAME should contain the same Cloudinary cloud name.
# CLD_CLOUD_NAME=
# CLD_API_KEY= 
# CLD_API_SECRET= 

# Proxy Authentication Token
# This token must match the PROXY_API_TOKEN secret in GitHub Actions
# and will be injected into api/.env.php on the server.
PROXY_API_TOKEN=
